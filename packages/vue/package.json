{
  "name": "@bidilens/vue",
  "version": "0.1.0",
  "description": "Vue 3 bidirectional message component and composable.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": ["bidi", "rtl", "ltr", "unicode", "vue", "ai"],
  "files": ["dist", "README.md", "LICENSE", "examples"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" } },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "prepack": "pnpm run build",
    "example": "node examples/basic.mjs"
  },
  "dependencies": { "@bidilens/core": "workspace:*" },
  "peerDependencies": { "vue": ">=3.5 <4" },
  "devDependencies": { "@vue/server-renderer": "^3.5.0", "tsup": "^8.5.1", "vue": "^3.5.0" },
  "engines": { "node": ">=22.12.0" },
  "publishConfig": { "access": "public" }
}
