{
  "name": "@bidilens/react",
  "version": "0.1.0",
  "description": "React components and hooks for mixed RTL/LTR and streaming AI messages.",
  "license": "MIT",
  "author": { "name": "Shayan SalehiRad", "url": "https://github.com/CodeinScrubs" },
  "repository": { "type": "git", "url": "git+https://github.com/CodeinScrubs/BidiLens.git", "directory": "packages/react" },
  "homepage": "https://github.com/CodeinScrubs/BidiLens#readme",
  "bugs": { "url": "https://github.com/CodeinScrubs/BidiLens/issues" },
  "type": "module",
  "sideEffects": false,
  "keywords": ["bidi", "rtl", "ltr", "unicode", "react", "ai"],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --clean --sourcemap --external react --external react/jsx-runtime",
    "prepack": "pnpm run build",
    "example": "node examples/basic.mjs"
  },
  "dependencies": {
    "@bidilens/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "react-dom": "^19.2.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": { "node": ">=22.12.0" }
}
