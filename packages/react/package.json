{
  "name": "@bidilens/react",
  "version": "0.1.0",
  "description": "React components and hooks for mixed RTL/LTR and streaming AI messages.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --clean --sourcemap --external react --external react/jsx-runtime"
  },
  "dependencies": {
    "@bidilens/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "react-dom": "^19.2.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
