{
  "name": "@bidilens/markdown",
  "version": "0.1.0",
  "description": "remark and rehype plugins for mixed RTL/LTR Markdown.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": ["bidi", "rtl", "ltr", "unicode", "markdown", "ai"],
  "files": ["dist", "README.md", "LICENSE", "examples"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "prepack": "pnpm run build",
    "example": "node examples/basic.mjs"
  },
  "dependencies": {
    "@bidilens/core": "workspace:*",
    "@types/hast": "^3.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "markdown-it": "^14.0.0"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    }
  },
  "devDependencies": {
    "markdown-it": "^14.1.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsup": "^8.5.1",
    "unified": "^11.0.5"
  },
  "engines": { "node": ">=22.12.0" },
  "publishConfig": { "access": "public" }
}
