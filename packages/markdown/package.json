{
  "name": "@bidilens/markdown",
  "version": "0.1.0",
  "description": "remark and rehype plugins for mixed RTL/LTR Markdown.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap"
  },
  "dependencies": {
    "@bidilens/core": "0.1.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsup": "^8.5.1",
    "unified": "^11.0.5"
  },
  "publishConfig": { "access": "public" }
}
