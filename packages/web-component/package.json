{
  "name": "@bidilens/web-component",
  "version": "0.1.0",
  "description": "Framework-independent custom element for bidirectional AI messages.",
  "license": "MIT",
  "author": { "name": "Shayan SalehiRad", "url": "https://github.com/CodeinScrubs" },
  "repository": { "type": "git", "url": "git+https://github.com/CodeinScrubs/BidiLens.git", "directory": "packages/web-component" },
  "homepage": "https://github.com/CodeinScrubs/BidiLens#readme",
  "bugs": { "url": "https://github.com/CodeinScrubs/BidiLens/issues" },
  "type": "module",
  "sideEffects": ["./dist/auto.js", "./dist/standalone.js"],
  "keywords": ["bidi", "rtl", "ltr", "unicode", "web-component", "ai"],
  "files": ["dist", "README.md", "LICENSE", "examples"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/standalone.js",
  "jsdelivr": "./dist/standalone.js",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" },
    "./auto": { "types": "./dist/auto.d.ts", "import": "./dist/auto.js", "default": "./dist/auto.js" },
    "./standalone": { "types": "./dist/standalone.d.ts", "import": "./dist/standalone.js", "default": "./dist/standalone.js" }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "pnpm run build",
    "example": "node examples/basic.mjs"
  },
  "dependencies": { "@bidilens/core": "workspace:*" },
  "devDependencies": { "jsdom": "^29.1.1", "tsup": "^8.5.1" },
  "engines": { "node": ">=22.12.0" },
  "publishConfig": { "access": "public" }
}
