{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bidilens:schema:corpus-fixture:0.1.0",
  "type": "object",
  "required": [
    "id",
    "description",
    "text",
    "words",
    "expected",
    "tags",
    "curation",
    "nativeSpeakerReviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "description": { "type": "string", "minLength": 1 },
    "text": { "type": "string" },
    "words": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "expected": { "enum": ["ltr", "rtl", "neutral"] },
    "expectedVisualOrderRightToLeft": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "expectedVisualOrderLeftToRight": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "expectedIsolations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "direction", "kind"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "direction": { "enum": ["ltr", "rtl", "auto"] },
          "kind": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expectedSecurityCodes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "curation": { "enum": ["user-provided", "authored-template-matrix", "imported-comparison-corpus"] },
    "nativeSpeakerReviewed": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "expected": { "const": "rtl" } }, "required": ["expected"] },
      "then": {
        "properties": { "expectedVisualOrderRightToLeft": true },
        "required": ["expectedVisualOrderRightToLeft"]
      }
    },
    {
      "if": { "properties": { "expected": { "const": "ltr" } }, "required": ["expected"] },
      "then": {
        "properties": { "expectedVisualOrderLeftToRight": true },
        "required": ["expectedVisualOrderLeftToRight"]
      }
    }
  ]
}
