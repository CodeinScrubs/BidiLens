{
  "name": "bidilens",
  "version": "0.1.0",
  "private": true,
  "description": "Standards-first bidirectional text tooling for AI chat, Markdown, streaming UIs, and developer tools.",
  "license": "MIT",
  "author": {
    "name": "Shayan SalehiRad",
    "url": "https://github.com/CodeinScrubs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeinScrubs/BidiLens.git"
  },
  "homepage": "https://github.com/CodeinScrubs/BidiLens#readme",
  "bugs": {
    "url": "https://github.com/CodeinScrubs/BidiLens/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build && pnpm run action:build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "check": "pnpm run unicode:check && pnpm run typecheck && pnpm run lint && pnpm run packages:depth && pnpm run test:coverage && pnpm run corpus:check && pnpm run docs:check && pnpm run build && pnpm run action:check",
    "action:build": "esbuild action/src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=action/dist/index.cjs --sourcemap --legal-comments=external --log-override:empty-import-meta=silent",
    "action:check": "tsx scripts/check-action.ts",
    "demo": "pnpm --filter @bidilens/demo run dev",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:ci": "tsx scripts/benchmark.ts --output benchmarks/results/latest.json",
    "corpus:generate": "tsx scripts/generate-corpus.ts",
    "corpus:check": "tsx scripts/check-corpus.ts",
    "docs:check": "tsx scripts/check-docs.ts",
    "build:visual-fixtures": "pnpm --filter @bidilens/core run build && pnpm --filter @bidilens/markdown run build && pnpm --filter @bidilens/react run build && pnpm --filter @bidilens/web-component run build",
    "test:visual": "pnpm run build:visual-fixtures && playwright test",
    "unicode:generate": "tsx scripts/generate-bidi-data.ts",
    "unicode:download": "tsx scripts/generate-bidi-data.ts --download",
    "unicode:check": "tsx scripts/generate-bidi-data.ts --check",
    "release:check": "tsx scripts/release-check.ts",
    "packages:types": "tsx scripts/check-package-types.ts",
    "packages:depth": "tsx scripts/check-package-depth.ts",
    "sbom": "pnpm dlx @cyclonedx/cdxgen@12.7.1 -t js --no-install-deps --fail-on-error --spec-version 1.7 --json-pretty -o bidilens-sbom.cdx.json .",
    "sbom:check": "tsx scripts/check-sbom.ts",
    "deps:audit": "pnpm audit --audit-level low",
    "changeset": "changeset",
    "changeset:status": "changeset status"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/cli": "2.31.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "8.20.0",
    "esbuild": "0.28.1",
    "eslint": "^10.7.0",
    "fast-check": "^4.3.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.1.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "fast-uri": "3.1.4"
    }
  }
}
